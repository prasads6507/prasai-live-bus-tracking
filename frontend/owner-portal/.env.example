# Backend Environment Variables

# Server Configuration
PORT=3001
NODE_ENV=production

# Security
JWT_SECRET=your_jwt_secret_key_here_64_char_hex_recommended

# CORS (comma-separated for multiple origins, or * for all)
CORS_ORIGIN=*

# Firebase Service Account (Split into individual variables for Vercel compatibility)
# Get these from your Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_PROJECT_ID=live-bus-tracking-2ec59
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@live-bus-tracking-2ec59.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# IMPORTANT: When adding FIREBASE_PRIVATE_KEY to Vercel:
# 1. Copy the entire key including -----BEGIN PRIVATE KEY----- and -----END PRIVATE KEY-----
# 2. Keep the \n characters as literal text (Vercel will handle them)
# 3. Wrap in double quotes if needed
