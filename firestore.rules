rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner() {
      return isAuthenticated() && (
        request.auth.token.role == 'OWNER' || 
        request.auth.token.role == 'SUPER_ADMIN' ||
        request.auth.token.collegeId == 'OWNER_GLOBAL'
      );
    }

    function getCollegeId() {
      return request.auth.token.collegeId;
    }

    function isCollegeMember(collegeId) {
      return isOwner() || (isAuthenticated() && getCollegeId() == collegeId);
    }

    // ─── Colleges (Root) ─────────────────────────────────────────────
    match /colleges/{collegeId} {
      // Any user can read colleges for login/lookup
      allow read: if true;
      allow write: if isOwner();

      // ─── Scoped Sub-collections ────────────────────────────────────
      
      match /users/{uid} {
        allow read: if isCollegeMember(collegeId) || request.auth.uid == uid || (isAuthenticated() && request.auth.token.email == resource.data.email);
        allow update: if isAuthenticated() && (isOwner() || request.auth.uid == uid);
        allow create, delete: if isOwner();
      }

      match /students/{studentId} {
        allow read: if isCollegeMember(collegeId) || request.auth.uid == studentId || (isAuthenticated() && request.auth.token.email == resource.data.email);
        allow update: if isAuthenticated() && (isOwner() || request.auth.uid == studentId || (getCollegeId() == collegeId && request.auth.token.role == 'COLLEGE_ADMIN'));
        allow create: if isAuthenticated() && (isOwner() || (getCollegeId() == collegeId && request.auth.token.role == 'COLLEGE_ADMIN'));
        allow delete: if isOwner();
      }

      match /buses/{busId} {
        allow read: if isCollegeMember(collegeId);
        allow write: if isAuthenticated() && (isOwner() || (getCollegeId() == collegeId && (request.auth.token.role == 'DRIVER' || request.auth.token.role == 'COLLEGE_ADMIN')));

        match /trips/{tripId} {
          allow read: if isAuthenticated(); 
          allow write: if isAuthenticated() && (isOwner() || request.auth.token.role == 'DRIVER' || request.auth.token.role == 'COLLEGE_ADMIN');
        }
      }

      match /routes/{routeId} {
        allow read: if isCollegeMember(collegeId);
        allow write: if isOwner() || (getCollegeId() == collegeId && request.auth.token.role == 'COLLEGE_ADMIN');
      }

      match /stops/{stopId} {
        allow read: if isCollegeMember(collegeId);
        allow write: if isOwner() || (getCollegeId() == collegeId && request.auth.token.role == 'COLLEGE_ADMIN');
      }

      match /trips/{tripId} {
        allow read: if isCollegeMember(collegeId);
        allow write: if isAuthenticated() && (isOwner() || (getCollegeId() == collegeId && (request.auth.token.role == 'DRIVER' || request.auth.token.role == 'COLLEGE_ADMIN')));
        
        match /path/{pointId} {
          allow read: if isAuthenticated();
          allow write: if isAuthenticated() && (isOwner() || request.auth.token.role == 'DRIVER');
        }
      }

      match /attendance/{attendanceId} {
        allow read: if isCollegeMember(collegeId);
        allow write: if isAuthenticated() && (isOwner() || (getCollegeId() == collegeId && (request.auth.token.role == 'DRIVER' || request.auth.token.role == 'COLLEGE_ADMIN')));
      }

      match /stopArrivals/{arrivalId} {
        allow read: if isCollegeMember(collegeId);
        allow write: if isAuthenticated() && (isOwner() || request.auth.token.role == 'DRIVER');
      }

      match /notifications/{notificationId} {
        allow read: if isCollegeMember(collegeId);
        allow write: if isOwner() || (getCollegeId() == collegeId && request.auth.token.role == 'COLLEGE_ADMIN');
      }

      match /user_notifications/{notificationId} {
        allow read: if isAuthenticated() && (isOwner() || resource.data.studentId == request.auth.uid);
        allow update, delete: if isAuthenticated() && (isOwner() || resource.data.studentId == request.auth.uid);
        allow create: if false; // Admin SDK only
      }

      match /handoffs/{handoffId} {
        allow read, write: if isCollegeMember(collegeId);
      }
    }

    // ─── Catch-all ───────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if isOwner();
    }
  }
}
